# Environment variables for Xiuxian Mini Web

# Server Configuration
MINIWEB_HOST=0.0.0.0
MINIWEB_PORT=8787

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SEC=60

# Build ID (optional, auto-generated if not set)
# MINIWEB_BUILD_ID=

# Python Configuration
PYTHONUNBUFFERED=1
