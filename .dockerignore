.git
.gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
*.egg-info/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Database and data
data/
*.db

# Database backups
backups/
*.backup
*.db.backup*

# Documentation (build context only)
*.md
!README.md

# Docker
docker-compose*.yml
Dockerfile
.dockerignore

# Environment
.env
.env.*
!.env.example

# Test
tests/
*.test.js
*.spec.js

# CI/CD
.github/
.gitlab-ci.yml

# Temporary files
tmp/
temp/
*.tmp
